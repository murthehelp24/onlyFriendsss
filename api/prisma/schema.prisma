// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum genderStatus {
  MALE
  FEMALE
  OTHER
}

enum ActivityCategory {
  HEALTH
  ENTERTAINMENT
  ART
  FOOD
  TRAVEL
}

enum ActivityStatus {
  OPEN
  FULL
  FINISHED
  CANCELLED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
}

model User {
  id         Int          @id @default(autoincrement())
  firstName  String
  lastName   String
  email      String       @unique
  gender     genderStatus
  profileImg String?
  bio        String?
  isVerified Boolean      @default(false)
  createdAt  DateTime     @default(now())

  createdActivities Activity[]     @relation("UserCreatedActivities") // กิจกรรมที่ User นี้สร้าง
  joinRequests      JoinRequest[] // รายการที่ User นี้ไปขอจอยคนอื่น
  reviews           Review[] // รีวิวที่ User นี้เขียน
  visitedPlaces     VisitedPlace[]
  messages          Message[]

  sentFriendRequests     FriendShip[] @relation("SentFriendRequests")
  receivedFriendRequests FriendShip[] @relation("ReceivedFriendRequests")
}

model Activity {
  id              Int              @id @default(autoincrement())
  category        ActivityCategory
  title           String
  description     String
  maxParticipants Int
  status          ActivityStatus   @default(OPEN)
  eventDate       DateTime
  createdAt       DateTime         @default(now())

  hostId       Int
  host         User          @relation("UserCreatedActivities", fields: [hostId], references: [id])
  placeId      Int?
  place        Place?        @relation(fields: [placeId], references: [id])
  joinRequests JoinRequest[] // คนที่ขอเข้าร่วมกิจกรรมนี้
  reviews      Review[] // รีวิวที่เกิดในกิจกรรมนี้
  chatGroup    ChatGroup?
}

model JoinRequest {
  id        Int           @id @default(autoincrement())
  status    RequestStatus @default(PENDING)
  createdAt DateTime      @default(now())

  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  activityId Int
  activity   Activity @relation(fields: [activityId], references: [id])
}

model Place {
  id        Int    @id @default(autoincrement())
  placeName String
  latitude  Float
  longitude Float
  address   String

  visitedBy  VisitedPlace[]
  activities Activity[]
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  imageUrl  String?
  createdAt DateTime @default(now())

  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  activityId Int
  activity   Activity @relation(fields: [activityId], references: [id])
}

model FriendShip {
  id        Int              @id @default(autoincrement())
  status    FriendshipStatus @default(PENDING)
  createdAt DateTime         @default(now())

  senderId   Int
  sender     User @relation("SentFriendRequests", fields: [senderId], references: [id])
  receiverId Int
  receiver   User @relation("ReceivedFriendRequests", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId]) // กันส่งคำขอซ้ำ
}

model VisitedPlace {
  id Int @id @default(autoincrement())

  userId  Int
  user    User  @relation(fields: [userId], references: [id])
  placeId Int
  place   Place @relation(fields: [placeId], references: [id])
}

model ChatGroup {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // เชื่อมกับ Activity (1 กิจกรรม มี 1 ห้องแชท)
  activityId Int      @unique
  activity   Activity @relation(fields: [activityId], references: [id])

  // ในห้องแชทมีหลายข้อความ
  messages Message[]
}

model Message {
  id        Int      @id @default(autoincrement())
  content   String // เนื้อหาข้อความ
  createdAt DateTime @default(now())

  // ใครเป็นคนส่ง
  senderId Int
  sender   User @relation(fields: [senderId], references: [id])

  // ส่งที่ห้องไหน
  chatGroupId Int
  chatGroup   ChatGroup @relation(fields: [chatGroupId], references: [id])
}
